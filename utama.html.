<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Memories</title>
    <style>
        body { background: #ffafbd; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; font-family: sans-serif; }
        .card { background: white; padding: 40px; border-radius: 20px; text-align: center; box-shadow: 0 10px 20px rgba(0,0,0,0.1); width: 80%; }
        button { background: #d81b60; color: white; border: none; padding: 20px; border-radius: 10px; font-size: 18px; width: 100%; cursor: pointer; }
    </style>
</head>
<body>

    <div id="box" class="card">
        <h2>Halo Sayang 🌸</h2>
        <p>Klik tombol di bawah untuk musiknya</p>
        <!-- TOMBOL UTAMA -->
        <button onclick="putar()">KLIK UNTUK PUTAR LAGU ✨</button>
    </div>

    <div id="konten" style="display:none; text-align:center; color:white;">
        <h1>❤️ Aku Milikmu ❤️</h1>
        <div id="musik"></div>
    </div>

    <script>
        function putar() {
            // Sembunyikan tombol, munculkan konten
            document.getElementById('box').style.display = 'none';
            document.getElementById('konten').style.display = 'block';
            
            // Masukkan lagu YouTube Dewa 19 - Aku Milikmu
            document.getElementById('musik').innerHTML = `
                <iframe width="0" height="0" 
                src="https://www.youtube.com/embed/gT9g1cW1H-4?autoplay=1&loop=1&playlist=gT9g1cW1H-4" 
                frameborder="0" allow="autoplay"></iframe>`;
        }
    </script>
</body>
</html>
